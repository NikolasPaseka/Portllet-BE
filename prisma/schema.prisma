generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Currency {
  CZK
  USD
}

enum AccountType {
  common
  saving
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  cashBalance     CashBalance?
  banks           Bank[]
  bankAccounts    BankAccount[]
  stocks          Stock[]
  cryptos         Crypto[]
  otherAssets     OtherAsset[]
  refreshTokens   RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model CashBalance {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  amount   Decimal  @default(0) @db.Decimal(18, 4)
  currency Currency @default(CZK)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cash_balances")
}

model Bank {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts BankAccount[]

  @@unique([userId, name])
  @@map("banks")
}

model BankAccount {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  bankId       String      @map("bank_id")
  name         String
  type         AccountType
  balance      Decimal     @default(0) @db.Decimal(18, 4)
  currency     Currency
  interestRate Decimal?    @map("interest_rate") @db.Decimal(5, 2)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank         Bank          @relation(fields: [bankId], references: [id], onDelete: Restrict)
  envelopes    Envelope[]
  interestLogs InterestLog[]

  @@map("bank_accounts")
}

model Envelope {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  name          String
  targetAmount  Decimal  @map("target_amount") @db.Decimal(18, 4)
  currentAmount Decimal  @default(0) @map("current_amount") @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")

  bankAccount BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("envelopes")
}

model InterestLog {
  id               String   @id @default(uuid())
  accountId        String   @map("account_id")
  previousBalance  Decimal  @map("previous_balance") @db.Decimal(18, 4)
  interestAmount   Decimal  @map("interest_amount") @db.Decimal(18, 4)
  newBalance       Decimal  @map("new_balance") @db.Decimal(18, 4)
  interestRate     Decimal  @map("interest_rate") @db.Decimal(5, 2)
  appliedAt        DateTime @default(now()) @map("applied_at")

  bankAccount BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("interest_logs")
}

model Stock {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  ticker    String
  shares    Decimal  @db.Decimal(18, 8)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stocks")
}

model Crypto {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  symbol    String
  amount    Decimal  @db.Decimal(18, 8)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cryptos")
}

model OtherAsset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  value     Decimal  @db.Decimal(18, 4)
  currency  Currency
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("other_assets")
}
